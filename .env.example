# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# n8n Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your-n8n-api-key
N8N_BASE_URL=http://localhost:5678

# Upstash Redis (Circuit Breaker Cache)
UPSTASH_REDIS_URL=https://default:password@region.upstash.io:port
UPSTASH_REDIS_TOKEN=your-upstash-token

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourapp.com
ESCALATION_EMAIL=ops-team@yourapp.com

# Grafana Configuration
GRAFANA_API_KEY=your-grafana-api-key
GRAFANA_BASE_URL=http://localhost:3000

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_P0_CHANNEL=https://hooks.slack.com/services/YOUR/P0/WEBHOOK
SLACK_P1_CHANNEL=https://hooks.slack.com/services/YOUR/P1/WEBHOOK

# Trigger.dev
TRIGGER_API_KEY=your-trigger-api-key
TRIGGER_PROJECT_ID=your-project-id

# Monitoring & Observability
DATADOG_API_KEY=your-datadog-api-key
SENTRY_DSN=your-sentry-dsn

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
ENVIRONMENT=production

# Database (for local development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/integration_health

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0

# Client-specific settings
HEALTH_CHECK_INTERVAL_MINUTES=5
INCIDENT_DETECTION_WINDOW_SECONDS=300
CIRCUIT_BREAKER_ERROR_THRESHOLD_PCT=25
CIRCUIT_BREAKER_WINDOW_SECONDS=300
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3
SLA_BREACH_ESCALATION_THRESHOLD_PCT=1

# Feature Flags
ENABLE_INCIDENT_CORRELATION=true
ENABLE_FUNNEL_ANALYSIS=true
ENABLE_WEBHOOK_RETRY_LOGIC=true
ENABLE_AUTOMATIC_FALLBACK=true

# Retention Policies (days)
EVENT_RETENTION_DAYS=90
INCIDENT_RETENTION_DAYS=365
HEALTH_SNAPSHOT_RETENTION_DAYS=30
