          "rawSql": "SELECT\n  DATE_TRUNC('hour', fse.started_at) as time,\n  ROUND(AVG(CASE WHEN fse.outcome = 'completed' THEN 100 ELSE 0 END), 1) as funnel_completion,\n  ROUND(AVG(CASE WHEN fse.api_provider_id IS NOT NULL THEN 1 ELSE 0 END) * 100, 1) as api_dependency_calls\nFROM funnel_step_events fse\nWHERE fse.started_at >= NOW() - INTERVAL '7 days'\n  AND fse.client_id = '$client_id'\nGROUP BY DATE_TRUNC('hour', fse.started_at)\nORDER BY time DESC",
