        {
          "datasource": "Supabase",
          "format": "table",
          "rawSql": "SELECT\n  step_id,\n  step_order,\n  ROUND(100.0 * SUM(CASE WHEN outcome = 'completed' THEN 1 ELSE 0 END) / COUNT(*), 1) as completion_rate,\n  ROUND(100.0 * SUM(CASE WHEN outcome IN ('dropped_off', 'error', 'timeout') THEN 1 ELSE 0 END) / COUNT(*), 1) as drop_off_rate\nFROM funnel_step_events\nWHERE started_at >= NOW() - INTERVAL '24 hours'\n  AND client_id = '$client_id'\nGROUP BY step_id, step_order\nORDER BY step_order",
          "refId": "A"
        }
      ],
      "title": "Onboarding Funnel Conversion Rates (24h)",
      "type": "timeseries"
