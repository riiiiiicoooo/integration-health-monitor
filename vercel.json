{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/**/*.{jsx,js,tsx,ts}",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE"]
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "N8N_WEBHOOK_URL": "@n8n_webhook_url",
    "UPSTASH_REDIS_URL": "@upstash_redis_url",
    "RESEND_API_KEY": "@resend_api_key",
    "GRAFANA_API_KEY": "@grafana_api_key",
    "SLACK_WEBHOOK_URL": "@slack_webhook_url",
    "ESCALATION_EMAIL": "@escalation_email"
  },
  "crons": [
    {
      "path": "/api/cron/health-check-batch",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/scorecard-generation",
      "schedule": "0 1 1 * *"
    },
    {
      "path": "/api/cron/clean-old-events",
      "schedule": "0 3 * * 0"
    }
  ],
  "functions": {
    "api/webhooks/incidents.ts": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/webhooks/health-check.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/health-check-batch.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/cron/scorecard-generation.ts": {
      "memory": 512,
      "maxDuration": 180
    }
  }
}
