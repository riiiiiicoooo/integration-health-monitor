FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY dashboard/package*.json ./

# Install dependencies
RUN npm ci

# Copy dashboard code
COPY dashboard/ .

# Build the application
RUN npm run build

# Expose port
EXPOSE 3000

# Start the development server (use 'npm start' for dev, would need build for prod)
CMD ["npm", "start"]
